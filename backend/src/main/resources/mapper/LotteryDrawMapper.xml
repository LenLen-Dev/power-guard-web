<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.scorpio.powerguard.mapper.LotteryDrawMapper">

    <resultMap id="LotteryDrawResultMap" type="com.scorpio.powerguard.entity.LotteryDraw">
        <id property="id" column="id"/>
        <result property="drawKey" column="draw_key"/>
        <result property="drawTime" column="draw_time"/>
        <result property="winnerCount" column="winner_count"/>
        <result property="message" column="message"/>
        <result property="createTime" column="create_time"/>
    </resultMap>

    <sql id="BaseColumns">
        id, draw_key, draw_time, winner_count, message, create_time
    </sql>

    <insert id="insert" parameterType="com.scorpio.powerguard.entity.LotteryDraw" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO lottery_draw (
            draw_key, draw_time, winner_count, message, create_time
        ) VALUES (
            #{drawKey}, #{drawTime}, #{winnerCount}, #{message}, #{createTime}
        )
    </insert>

    <select id="selectByDrawKey" resultMap="LotteryDrawResultMap">
        SELECT <include refid="BaseColumns"/>
        FROM lottery_draw
        WHERE draw_key = #{drawKey}
        LIMIT 1
    </select>

    <select id="selectLatest" resultMap="LotteryDrawResultMap">
        SELECT <include refid="BaseColumns"/>
        FROM lottery_draw
        ORDER BY draw_time DESC, id DESC
        LIMIT 1
    </select>
</mapper>
